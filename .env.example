# Huangting-Flux Hub — Environment Variables
# Copy this file to .env and fill in your values.

# --- Application ---
APP_NAME="Huangting-Flux Hub"
DEBUG=false

# --- Security ---
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/huangting_flux
DATABASE_URL_SYNC=postgresql://postgres:your_password@localhost:5432/huangting_flux

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- CORS ---
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000","https://huangting.ai"]
